        function getElastModifiers() {
            const isCustomActive = document.getElementById('chk-custom-elast').checked;
            if (isCustomActive) {
                return {
                    tDrop: (+document.getElementById('celast-t').value || 0) / 100,
                    crDrop: (+document.getElementById('celast-cr').value || 0) / 100
                };
            }
            const cat = document.getElementById('biz-cat').value;
            const biz = BIZ[cat];
            return { tDrop: biz.tDrop / 100, crDrop: biz.crDrop / 100 };
        }

        function getRawInputs() {
            let price = parseFormattedNum('in-price');
            let traffic = parseFormattedNum('in-traffic');
            let cr = (+document.getElementById('in-cr').value || 0) / 100;
            let fixed = parseFormattedNum('in-fixed');
            let retention = (+document.getElementById('in-ret').value || 0) / 100;

            let cogs = parseFormattedNum('in-cogs');
            return { price, cogs, traffic, cr, fixed, retention };
        }

        function calcMetrics(price, cogs, traffic, cr, fixed, retention) {
            const qty = traffic * cr;
            const baseRev = qty * price;
            const repeatQty = qty * retention;
            const extraRev = repeatQty * price;

            const totalQty = qty + repeatQty;
            const totalRev = baseRev + extraRev;

            let mktVarTotal = 0;
            let mktFixedTotal = 0;

            if (mktTab === 'simple') {
                mktVarTotal = parseFormattedNum('m-cpc') * traffic;
            } else {
                const platFee = (parseFloat($('m-plat').value) || 0) / 100 * totalRev;
                const pgwFee = (parseFloat($('m-pgw').value) || 0) / 100 * totalRev;
                const shipSub = parseFormattedNum('m-ship') * totalQty;
                const affPct = (parseFloat($('m-aff-pct').value) || 0) / 100 * totalRev;
                const affFix = parseFormattedNum('m-aff-fix') * totalQty;
                const distFee = parseFormattedNum('m-dist') * totalQty;
                
                mktVarTotal = platFee + pgwFee + shipSub + affPct + affFix + distFee;
                mktFixedTotal = parseFormattedNum('m-ads') + parseFormattedNum('m-kol');
            }

            const totalMarketingCost = mktVarTotal + mktFixedTotal;
            const totalCOGS = totalQty * cogs;
            const grossProfit = totalRev - totalCOGS - totalMarketingCost;
            const netProfit = grossProfit - fixed;
                        
            // Blended ROAS: Rev / Cluster C (Fixed acquisition spend)
            const roas = mktFixedTotal > 0 ? (totalRev / mktFixedTotal) : 0;
            
            const marginPct = totalRev > 0 ? (grossProfit / totalRev * 100) : 0;

             return { totalQty, totalRev, totalCOGS, mktTotal: totalMarketingCost, grossProfit, netProfit, marginPct, baseQty: qty, baseRev, roas };
       }

        function applyLiveElasticity(price, tDropFactor, crDropFactor) {
            const warningEl = document.getElementById('price-warning');

            // Hanya jalankan logika modifikasi elastisitas jika baseline sudah dikunci
            if (!isBaselineLocked) {
                warningEl.style.display = 'none';
                return;
            }

            const priceRatio = price / dynamicBaselinePrice;
            // Menghitung interval kenaikan/penurunan harga per 10%
            const smoothedIntervals = Math.log(priceRatio) / Math.log(1.10);

            if (price !== dynamicBaselinePrice) {
                // Jika price > baseline: smoothedIntervals positif (traffic & CR turun)
                // Jika price < baseline: smoothedIntervals negatif (traffic & CR naik)
                
                // Kita gunakan rumus: baseline * (1 - (intervals * dropFactor))
                // Contoh: Jika harga turun 10%, intervals = -1. multiplier = (1 - (-1 * drop)) = 1 + drop.
                const trafficMult = 1 - (smoothedIntervals * tDropFactor);
                const crMult = 1 - (smoothedIntervals * crDropFactor);

                // Safety clamping: traffic tidak boleh < 10, CR tidak boleh < 0.1%
                // Dan untuk kenaikan (gain), kita batasi maksimal 3x lipat dari baseline agar realistis
                const targetT = Math.max(10, Math.min(initialTrafficBeforeDrag * 3, Math.round(initialTrafficBeforeDrag * trafficMult)));
                const targetCR = Math.max(0.1, Math.min(100, +(initialCrBeforeDrag * crMult).toFixed(2)));

                // Hanya timpa nilai jika User sedang merubah HARGA (bukan merubah traffic/cr itu sendiri)
                if (lastFreeInput === 'price') {
                    syncTrafficInputAndSlider(targetT);
                    document.getElementById('in-cr').value = targetCR;
                    document.getElementById('sl-cr').value = Math.min(100, targetCR);
                }

                warningEl.style.display = 'block';
                if (price > dynamicBaselinePrice) {
                    warningEl.innerHTML = `<i class="ti ti-alert-triangle"></i> <strong>Efek Elastisitas (Penalti):</strong> Kenaikan harga +${((priceRatio - 1) * 100).toFixed(0)}% menurunkan kapasitas pasar (Traffic: -${((1 - trafficMult) * 100).toFixed(1)}% | CR: -${((1 - crMult) * 100).toFixed(1)}%).`;
                } else {
                    warningEl.innerHTML = `<i class="ti ti-trending-up" style="color:var(--color-text-success)"></i> <strong>Efek Elastisitas (Insentif):</strong> Penurunan harga ${((1 - priceRatio) * 100).toFixed(0)}% meningkatkan potensi pasar (Traffic: +${((trafficMult - 1) * 100).toFixed(1)}% | CR: +${((crMult - 1) * 100).toFixed(1)}%).`;
                    warningEl.style.background = 'var(--color-background-info)';
                    warningEl.style.borderLeftColor = 'var(--color-text-info)';
                    warningEl.style.color = 'var(--color-text-info)';
                }
            } else {
                warningEl.style.display = 'none';
            }
        }

        function solveConstraints() {
            let { price, cogs, traffic, cr, fixed, retention } = getRawInputs();
            const tRev = LOCKS.rev ? parseFormattedNum('in-rev') : null;
            const tGP = LOCKS.gp ? parseFormattedNum('in-gp') : null;

            if (!tRev && !tGP) return;

            const biz = BIZ[document.getElementById('biz-cat').value];
            const crMin = biz.crMin / 100, crMax = biz.crMax / 100;

            const currentMetrics = calcMetrics(price, cogs, traffic, cr, fixed, retention);
            if (tRev !== null && currentMetrics.totalRev >= tRev) return;
            if (tGP !== null && currentMetrics.grossProfit >= tGP) return;

            // Proteksi Margin Kontribusi
            const unitContrib = calcUnitContribution(price, cogs, cr, retention);
            if (unitContrib <= 0 && tGP !== null) return;

            let unitsNeeded = 0;
            if (tRev !== null && tRev > 0) {
                const totalPerUnit = price * (1 + retention);
                if (totalPerUnit <= 0) return;
                unitsNeeded = tRev / totalPerUnit;
            } else if (tGP !== null && tGP > 0) {
                unitsNeeded = calcUnitsNeededForTarget(price, cogs, cr, retention, tGP);
            }

            if (unitsNeeded <= 0) return;

            let finalTraffic = traffic, finalCr = cr;

            if (lastFreeInput === 'cr') {
                finalTraffic = cr > 0 ? (unitsNeeded / cr) : 0;
                const maxT = +document.getElementById('sl-traffic').max || 500000;
                if (finalTraffic > maxT) finalTraffic = maxT;
            } else if (lastFreeInput === 'traffic') {
                finalCr = traffic > 0 ? (unitsNeeded / traffic) : 0;
                if (finalCr > crMax) { finalCr = crMax; finalTraffic = crMax > 0 ? (unitsNeeded / crMax) : 0; }
                else if (finalCr < crMin) { finalCr = crMin; finalTraffic = crMin > 0 ? (unitsNeeded / crMin) : 0; }
            } else {
                let anchorTraffic = isBaselineLocked ? storedBaselineData.traffic : initialTrafficBeforeDrag;
                let anchorCr = isBaselineLocked ? storedBaselineData.cr : (initialCrBeforeDrag / 100);
                let splitRatio = (+document.getElementById('sl-weight-split').value || (biz.splitDefault * 100)) / 100;
                let dist = calcBalancedDistribution(unitsNeeded, anchorTraffic, anchorCr, biz, splitRatio);
                finalTraffic = dist.traffic; finalCr = dist.cr;
            }

            syncTrafficInputAndSlider(finalTraffic);
            document.getElementById('in-cr').value = +(finalCr * 100).toFixed(2);
            document.getElementById('sl-cr').value = Math.min(biz.crMax, finalCr * 100);
        }

        function update() {
            if (internalMutex) return;
            internalMutex = true;

            const cat = document.getElementById('biz-cat').value;
            const biz = BIZ[cat];
            const mods = getElastModifiers();

            const isCustomActive = document.getElementById('chk-custom-elast').checked;
            document.getElementById('elast-status-bar').textContent = isCustomActive ?
                `Custom Sektoral (Drop Traffic: -${(mods.tDrop * 100).toFixed(0)}% | Drop CR: -${(mods.crDrop * 100).toFixed(0)}%)` :
                `${biz.label} (Default Industri: Drop Traffic -${biz.tDrop}% | Drop CR -${biz.crDrop}%)`;

            const currentPrice = parseFormattedNum('in-price');
            let currentCogs = parseFormattedNum('in-cogs');
            const blendedPctEl = $('in-blended-pct');
            const cogsEl = $('in-cogs');
            const slCogsEl = $('sl-cogs');
            
            if (lastFreeInput === 'margin') {
                const targetPct = parseFloat(blendedPctEl.value) || 0;
                currentCogs = currentPrice * (1 - (targetPct / 100));
                LOCKS.cogs = true;
                renderLockInterface();
                cogsEl.value = Math.round(currentCogs).toLocaleString('id-ID');
                slCogsEl.value = Math.round(currentCogs);
            } else {
                const currentMargin = currentPrice > 0 ? (1 - (currentCogs / currentPrice)) * 100 : 0;
                blendedPctEl.value = currentMargin.toFixed(1);
            }

            if (!checkValidationEngine(currentPrice, currentCogs)) { internalMutex = false; return; }

            applyLiveElasticity(currentPrice, getElastModifiers().tDrop, getElastModifiers().crDrop);
            solveConstraints();

            const inputs = getRawInputs();
            
            const m = calcMetrics(inputs.price, inputs.cogs, inputs.traffic, inputs.cr, inputs.fixed, inputs.retention);

            document.getElementById('main-metrics').innerHTML = `
                <div class="mc"><div class="ml">Total Volume Jual</div><div class="mv">${fmtN(m.totalQty)} Unit</div></div>
                <div class="mc"><div class="ml">Revenue Omset</div><div class="mv">${fmt(m.totalRev)}</div></div>
                <div class="mc"><div class="ml" style="color:var(--color-text-success)">Gross Profit Tim</div><div class="mv good">${fmt(m.grossProfit)}</div></div>
                <div class="mc"><div class="ml">Margin Operasional</div><div class="mv">${fmtP(m.marginPct)}</div></div>
                <div class="mc"><div class="ml">Biaya Marketing</div><div class="mv warn">${fmt(m.mktTotal)}</div></div>
            `;

            // Visual Feedback pada Slider
            const isLoss = inputs.cogs > inputs.price;
            const slPrice = $('sl-price');
            const slCogs = $('sl-cogs');
            if (isLoss) {
                slPrice.style.accentColor = 'var(--color-text-danger)';
                slCogs.style.accentColor = 'var(--color-text-danger)';
            } else {
                slPrice.style.accentColor = '#3b82f6';
                slCogs.style.accentColor = '#3b82f6';
            }
            
            $('roas-val').textContent = m.roas.toFixed(1) + 'x';
            
            const ownerNetProfitEl = $('owner-net-profit');
            ownerNetProfitEl.textContent = fmt(m.netProfit);
            ownerNetProfitEl.className = m.netProfit < 0 ? 'mv bad' : 'mv good';

            renderVisualShadowIndicators(inputs);

            // PERBAIKAN 2: Penyaluran parameter murni aman tanpa interupsi loop DOM
            updateSweetSpotChart(inputs.price, inputs.cogs, inputs.traffic, inputs.cr, inputs.fixed, inputs.retention, mods.tDrop, mods.crDrop);

            renderParetoSection(inputs, m, biz);
            renderComparisonTable(inputs.price, inputs.cogs, inputs.traffic, inputs.cr, m);
            renderContextualTips(inputs, m, biz);
            renderReportOutput(inputs, m, biz);

            internalMutex = false;

            // Update Narasi Retensi Singkat
            const retVal = inputs.retention * 100;
            const retNarr = document.getElementById('ret-narr');
            if (retVal > 0) retNarr.textContent = `Efek LTV: +${retVal.toFixed(0)}% volume transaksi dari pelanggan lama.`;
            else retNarr.textContent = "";
        }

        function updateSweetSpotChart(price, cogs, traffic, cr, fixed, retention, tDrop, crDrop) {
            const pricePoints = [];
            const profitPoints = [];
            const baseProfitPoints = [];

             const currentCogs = cogs; // COGS statis untuk simulasi sweet spot

            for (let i = -4; i <= 4; i++) {
                const factor = 1 + (i * 0.08);
                const testPrice = price * factor;
                let testTraffic = traffic;
                let testCR = cr;

                const testCogs = currentCogs; // HPP tidak berubah saat mensimulasikan harga di grafik


                if (testPrice > dynamicBaselinePrice) {
                    const priceRatio = testPrice / dynamicBaselinePrice;
                    const smoothedIntervals = Math.log(priceRatio) / Math.log(1.10);

                    testTraffic = traffic * (1 - Math.min(0.95, smoothedIntervals * tDrop));
                    testCR = cr * (1 - Math.min(0.95, smoothedIntervals * crDrop));
                }

                const gp = calcMetrics(testPrice, testCogs, Math.max(10, testTraffic), Math.max(0.001, testCR), fixed, retention).grossProfit;
                pricePoints.push(Math.round(testPrice).toLocaleString('id-ID'));
                profitPoints.push(gp);

                if (isBaselineLocked) {
                    let baseTraffic = storedBaselineData.traffic;
                    let baseCR = storedBaselineData.cr;
                    const baseCogs = storedBaselineData.cogs; // Baseline HPP juga statis

                    if (testPrice > storedBaselineData.price) {
                        const priceRatio = testPrice / storedBaselineData.price;
                        const smoothedIntervals = Math.log(priceRatio) / Math.log(1.10);

                        baseTraffic = storedBaselineData.traffic * (1 - Math.min(0.95, smoothedIntervals * storedBaselineData.tDrop));
                        baseCR = storedBaselineData.cr * (1 - Math.min(0.95, smoothedIntervals * storedBaselineData.crDrop));
                    }
                    const baseGpVal = calcMetrics(testPrice, baseCogs, Math.max(10, baseTraffic), Math.max(0.001, baseCR), storedBaselineData.fixed, storedBaselineData.retention).grossProfit;
                    baseProfitPoints.push(baseGpVal);
                }
            }

            const datasets = [
                {
                    label: 'Profit Skenario Aktif',
                    data: profitPoints,
                    borderColor: '#3b82f6',
                    backgroundColor: 'rgba(59, 130, 246, 0.06)',
                    fill: true,
                    tension: 0.2,
                    pointRadius: [3, 3, 3, 3, 6, 3, 3, 3, 3],
                    pointBackgroundColor: ['#3b82f6', '#3b82f6', '#3b82f6', '#3b82f6', '#2563eb', '#3b82f6', '#3b82f6', '#3b82f6', '#3b82f6']
                }
            ];

            if (isBaselineLocked) {
                datasets.push({
                    label: 'Profit Baseline Terkunci',
                    data: baseProfitPoints,
                    borderColor: '#94a3b8',
                    backgroundColor: 'transparent',
                    fill: false,
                    tension: 0.2,
                    pointRadius: 0,
                    borderDash: [5, 5]
                });
            }

            if (!sweetSpotChart) {
                const ctx = document.getElementById('sweet-spot-chart').getContext('2d');
                sweetSpotChart = new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: pricePoints,
                        datasets: datasets
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: {
                            legend: { display: isBaselineLocked },
                            verticalLines: true
                        },
                        scales: {
                            y: { ticks: { callback: v => 'Rp ' + v.toLocaleString('id-ID') }, grid: { color: 'rgba(0,0,0,0.03)' } },
                            x: { grid: { display: false } }
                        }
                    },
                    plugins: [{
                        id: 'verticalLines',
                        afterDraw: (chart) => {
                            const ctx = chart.ctx;
                            const xAxis = chart.scales.x;
                            const yAxis = chart.scales.y;

                            const currentX = xAxis.getPixelForTick(4);
                            ctx.save();
                            ctx.beginPath();
                            ctx.strokeStyle = 'rgba(59, 130, 246, 0.4)';
                            ctx.lineWidth = 1.5;
                            ctx.moveTo(currentX, yAxis.top);
                            ctx.lineTo(currentX, yAxis.bottom);
                            ctx.stroke();
                            ctx.restore();

                            if (!isBaselineLocked) return;

                            const bPrice = storedBaselineData.price;
                            const baseFactor = bPrice / price;
                            const fractionalI = (baseFactor - 1) / 0.08;
                            const index = fractionalI + 4;

                            if (index >= 0 && index <= 8) {
                                const x_floor = xAxis.getPixelForTick(Math.floor(index));
                                const x_ceil = xAxis.getPixelForTick(Math.min(8, Math.ceil(index)));
                                const x = x_floor + (x_ceil - x_floor) * (index - Math.floor(index));

                                ctx.save();
                                ctx.beginPath();
                                ctx.strokeStyle = '#f59e0b';
                                ctx.lineWidth = 1.5;
                                ctx.setLineDash([4, 4]);
                                ctx.moveTo(x, yAxis.top);
                                ctx.lineTo(x, yAxis.bottom);
                                ctx.stroke();

                                ctx.fillStyle = '#d97706';
                                ctx.font = 'bold 10px sans-serif';
                                ctx.textAlign = 'center';
                                ctx.fillText('Baseline', x, yAxis.top - 4);
                                ctx.restore();

                                const bm = calcMetrics(storedBaselineData.price, storedBaselineData.cogs, storedBaselineData.traffic, storedBaselineData.cr, storedBaselineData.fixed, storedBaselineData.retention);
                                const yVal = yAxis.getPixelForValue(bm.grossProfit);

                                ctx.save();
                                ctx.beginPath();
                                ctx.arc(x, yVal, 6, 0, 2 * Math.PI);
                                ctx.fillStyle = '#f59e0b';
                                ctx.strokeStyle = '#ffffff';
                                ctx.lineWidth = 2;
                                ctx.fill();
                                ctx.stroke();
                                ctx.restore();
                            }
                        }
                    }]
                });
            } else {
                sweetSpotChart.data.labels = pricePoints;
                sweetSpotChart.data.datasets = datasets;
                sweetSpotChart.options.plugins.legend.display = isBaselineLocked;
                sweetSpotChart.update('none');
            }
        }

        function renderParetoSection(inputs, m, biz) {
            const gpValue = parseFormattedNum('in-gp');
            const isTargetGpFilled = LOCKS.gp && gpValue > 0;
            const parent = $('pareto-opts');
            const headline = $('pareto-headline-bar');
            const sliderContainer = $('balanced-slider-container');

            if (!isTargetGpFilled) {
                headline.innerHTML = `<i class="ti ti-info-circle" style="color: var(--color-text-warning)"></i> Masukkan dan kunci <strong>Target Gross Profit Minimal</strong> di panel parameter sebelah kiri untuk melihat rekomendasi optimasi Pareto.`;
                parent.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:24px;color:var(--color-text-secondary);border:1px dashed var(--color-border-tertiary);border-radius:8px;background:var(--color-background-secondary);width:100%"><i class="ti ti-target" style="font-size:24px;display:block;margin-bottom:8px;color:var(--color-text-tertiary);"></i>Silakan isi <strong>Target Gross Profit Minimal (Rp)</strong> dan klik tombol kunci <i class="ti ti-lock-open"></i> di sebelah kiri untuk mengaktifkan analisis optimasi Pareto.</div>`;
                sliderContainer.style.display = 'none';
                return;
            }

            // Tentukan jangkar (Anchor) perhitungan berdasarkan Baseline yang dikunci
            const anchorT = isBaselineLocked ? storedBaselineData.traffic : initialTrafficBeforeDrag;
            const anchorCr = isBaselineLocked ? storedBaselineData.cr : (initialCrBeforeDrag / 100);

            const crMin = biz.crMin / 100, crMax = biz.crMax / 100;
            const unitsNeeded = calcUnitsNeededForTarget(inputs.price, inputs.cogs, inputs.cr, inputs.retention, gpValue);

            // Opsi A: Optimasi CR (Traffic dikunci di Baseline)
            let crNeeded = anchorT > 0 ? (unitsNeeded / anchorT) : 0;
            let tNeededForA = anchorT;
            if (crNeeded > crMax) { crNeeded = crMax; tNeededForA = crMax > 0 ? (unitsNeeded / crMax) : 0; }
            else if (crNeeded < crMin) { crNeeded = crMin; tNeededForA = crMin > 0 ? (unitsNeeded / crMin) : 0; }
            
            const crDeltaA = anchorCr > 0 ? ((crNeeded - anchorCr) / anchorCr * 100) : 0;
            const tDeltaA = anchorT > 0 ? ((tNeededForA - anchorT) / anchorT * 100) : 0;

            // Opsi B: Scale Traffic (CR dikunci di Baseline)
            let tNeeded = anchorCr > 0 ? (unitsNeeded / anchorCr) : 0;
            let crNeededForB = anchorCr;
            if (tNeeded > 1000000) { tNeeded = 1000000; crNeededForB = Math.min(crMax, unitsNeeded / 1000000); }
            
            const tDeltaB = anchorT > 0 ? ((tNeeded - anchorT) / anchorT * 100) : 0;
            const crDeltaB = anchorCr > 0 ? ((crNeededForB - anchorCr) / anchorCr * 100) : 0;

            // Opsi C: balanced
            sliderContainer.style.display = 'block';
            let split = (+document.getElementById('sl-weight-split').value || (biz.splitDefault * 100)) / 100;
            document.getElementById('lbl-split-ratio').textContent = `${Math.round(split * 100)}% Traffic / ${Math.round((1 - split) * 100)}% CR`;
            let dist = calcBalancedDistribution(unitsNeeded, anchorT, anchorCr, biz, split);
            
            const balTDelta = anchorT > 0 ? ((dist.traffic - anchorT) / anchorT * 100) : 0;
            const balCrDelta = anchorCr > 0 ? ((dist.cr - anchorCr) / anchorCr * 100) : 0;

            headline.innerHTML = `<i class="ti ti-target-arrow"></i> Target acuan Gross Profit minimum solver saat ini: <strong>${fmt(gpValue)}</strong> (Klik kartu opsi di bawah untuk menerapkan rekomendasi ke slider)`;
            const isCrPareto = biz.effortCR === 'Rendah';

            const cards = [
                `<div class="optcard ${isCrPareto ? 'rec' : ''}" onclick="applyParetoPreset('A')">`,
                `<div class="octl">Opsi A: Optimasi Konversi ${isCrPareto ? '<span class="badge bp">Pareto</span>' : ''} <i class="ti ti-hand-click" style="font-size:11px;color:var(--color-text-secondary);"></i></div>`,
                `<div class="badge blo">Effort: ${biz.effortCR}</div>`,
                `<div style="font-size:12px;font-weight:600;margin-top:6px">CR Rasio: <strong>${(crNeeded * 100).toFixed(2)}%</strong></div>`,
                `<div style="font-size:11px;color:var(--color-text-info)">Delta dari Baseline: ${crDeltaA >= 0 ? '+' : ''}${crDeltaA.toFixed(1)}%</div>`,
