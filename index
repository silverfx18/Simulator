        function resetBaselineBenchmarks() {
            if (isBaselineLocked) {
                dynamicBaselinePrice = storedBaselineData.price;
                initialTrafficBeforeDrag = storedBaselineData.traffic;
                initialCrBeforeDrag = storedBaselineData.cr * 100;
                return;
            }
            dynamicBaselinePrice = parseFormattedNum('in-price') || 200000;
