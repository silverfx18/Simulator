        }

        // ─── PROFIT FLOOR ENFORCER ───────────────────────────────────────────
        // Dipanggil SETELAH nilai slider diubah user, SEBELUM update().
        // Logic:
        //   - slider CR turun → kalau profit >= target, biarkan
        //                     → kalau profit < target, naikkan traffic supaya profit kembali ke target
        //   - slider Traffic turun → sama, naikkan CR kalau kurang
        //   - slider Price turun → kalau profit jatuh di bawah target, block slider (kembalikan ke posisi lama)
        function enforceTargetProfitFloor(movedKey, previousValue) {
            const gpTarget = LOCKS.gp ? parseFormattedNum('in-gp') : 0;
            const revTarget = LOCKS.rev ? parseFormattedNum('in-rev') : 0;
            if (!gpTarget && !revTarget) return; // tidak ada target aktif, skip

            let { price, cogs, traffic, cr, fixed, retention } = getRawInputs();
            const biz = BIZ[document.getElementById('biz-cat').value];
            const m = calcMetrics(price, cogs, traffic, cr, fixed, retention);

            const metricBelowTarget = (gpTarget && m.grossProfit < gpTarget) || (revTarget && m.totalRev < revTarget);
            if (!metricBelowTarget) return; // masih aman, tidak perlu apa-apa

            // Proteksi Kontribusi Margin Negatif untuk Solver
            const contrib = calcUnitContribution(price, cogs, cr, retention);
            if (contrib <= 0 && (gpTarget > 0)) {
                // Revert slider jika margin sudah negatif sehingga tidak bisa di-solve
                const num = document.getElementById('in-' + movedKey);
                const sl = document.getElementById('sl-' + movedKey);
                num.value = previousValue;
                sl.value = previousValue;
                return;
            }

            if (movedKey === 'price') {
                // Harga turun bikin profit drop → block: kembalikan harga ke nilai sebelumnya
                document.getElementById('in-price').value = previousValue;
                document.getElementById('sl-price').value = previousValue;
                // Tampilkan notif
                const warn = document.getElementById('price-warning');
                warn.style.display = 'block';
                warn.style.background = '#fff0f0';
                warn.style.borderLeftColor = 'var(--color-text-danger)';
                warn.style.color = 'var(--color-text-danger)';
                warn.innerHTML = `<i class="ti ti-ban"></i> <strong>Slider Diblokir:</strong> Penurunan harga ini akan membuat profit jatuh di bawah target. Naikkan Traffic atau CR terlebih dahulu sebelum menurunkan harga lebih jauh.`;
                return; // jangan panggil update lagi
            }

            if (movedKey === 'cr') {
                // CR diturunkan → kompensasi dengan naikkan traffic
                const crMin = biz.crMin / 100, crMax = biz.crMax / 100;
                const unitsNeeded = gpTarget
                    ? calcUnitsNeededForTarget(price, cogs, cr, retention, gpTarget)
                    : (revTarget / (price * (1 + retention)));
                const newTraffic = cr > 0 ? Math.ceil(unitsNeeded / cr) : traffic;
                // Cap kompensasi traffic agar tidak melompat terlalu jauh (max 5x dari max slider saat ini)
                const currentMax = +document.getElementById('sl-traffic').max;
                syncTrafficInputAndSlider(Math.min(newTraffic, currentMax * 5));
            } else if (movedKey === 'traffic') {
                // Traffic diturunkan → kompensasi dengan naikkan CR
                const crMin = biz.crMin / 100, crMax = biz.crMax / 100;
                const unitsNeeded = gpTarget
                    ? calcUnitsNeededForTarget(price, cogs, cr, retention, gpTarget)
                    : (revTarget / (price * (1 + retention)));
                let newCR = traffic > 0 ? (unitsNeeded / traffic) : cr;
                // Cap CR sesuai batas atas kategori bisnis
                newCR = Math.min(crMax, newCR);
                document.getElementById('in-cr').value = +(newCR * 100).toFixed(2);
                document.getElementById('sl-cr').value = Math.min(biz.crMax, newCR * 100);
            }
        }

        function wireEvents(id, sliderId) {
            const num = document.getElementById(id);
            const sl = document.getElementById(sliderId);
            const key = id.replace('in-', '');
            const isCrField = id.includes('cr');
            let prevSliderVal = sl.value; // track previous untuk price-block

            const startTracking = () => { prevSliderVal = sl.value; resetBaselineBenchmarks(); };
            // Tambahkan tracking saat kotak input diklik/difokuskan agar baseline sinkron
            sl.addEventListener('mousedown', startTracking);
            sl.addEventListener('touchstart', startTracking);
            num.addEventListener('focus', startTracking);

            sl.addEventListener('input', () => {
                num.value = isCrField ? sl.value : parseInt(sl.value).toLocaleString('id-ID');
                lastFreeInput = key; 

                // LOGIKA: Baseline sebagai Floor Dinamis
                if (isBaselineLocked && (key === 'traffic' || key === 'cr')) {
                    const priceRatio = parseFormattedNum('in-price') / dynamicBaselinePrice;
                    const smoothedIntervals = Math.log(priceRatio) / Math.log(1.10);
                    const mods = getElastModifiers();
                    const factor = 1 - (smoothedIntervals * (key === 'traffic' ? mods.tDrop : mods.crDrop));
                    const dynamicFloor = (key === 'traffic' ? storedBaselineData.traffic : (storedBaselineData.cr * 100)) * Math.min(1, factor);
                    
                    if (parseFloat(sl.value) < dynamicFloor) { sl.value = dynamicFloor; num.value = isCrField ? sl.value : Math.round(dynamicFloor).toLocaleString('id-ID'); }
                }

                if (currentCapMode === 'strict') {
                    let p = parseFormattedNum('in-price');
                    let c = parseFormattedNum('in-cogs');
                    if (key === 'price' && p < c) {
                        num.value = c.toLocaleString('id-ID');
                        sl.value = c;
                    } else if (key === 'cogs' && c > p) {
                        document.getElementById('in-price').value = c.toLocaleString('id-ID');
                        document.getElementById('sl-price').value = c;
                        lastFreeInput = 'price'; // Trigger market reaction (elasticity)
                    }
                }
                if (LOCKS[key]) toggleLock(key);
                enforceTargetProfitFloor(key, prevSliderVal);
                update();
            });

            num.addEventListener('input', () => {
                if (!isCrField) formatInputThousand(num);
                lastFreeInput = key;
                const val = isCrField ? parseFloat(num.value) : parseFormattedNum(id);
                if (id === 'in-traffic' && val > +sl.max) sl.max = Math.round(val * 1.5);

                // Jika input manual AOV atau HPP melebihi batas, perbarui skala keduanya agar tetap sinkron
                if ((key === 'price' || key === 'cogs') && val > +sl.max) {
                    const newMax = Math.round(val * 1.5);
                    document.getElementById('sl-price').max = newMax;
                    document.getElementById('sl-cogs').max = newMax;
                }

                sl.value = val;
                
                // Hapus debounce 180ms agar respon pengetikan manual secepat slider
                update();
            });

            num.addEventListener('change', () => {
                prevSliderVal = isCrField ? parseFloat(num.value) : parseFormattedNum(id);
                resetBaselineBenchmarks();
                lastFreeInput = key;
                if (LOCKS[key]) toggleLock(key);
                enforceTargetProfitFloor(key, prevSliderVal);
                update();
            });
    }

    function syncCogsToPrice(p) {
        document.getElementById('in-cogs').value = p.toLocaleString('id-ID');
        document.getElementById('sl-cogs').value = p;
        }

        // BINDING EVENT HANDLER UTAMA
        wireEvents('in-price', 'sl-price');
        wireEvents('in-cogs', 'sl-cogs');
        wireEvents('in-traffic', 'sl-traffic');
        wireEvents('in-cr', 'sl-cr');

        document.getElementById('in-fixed').addEventListener('change', update);
        document.getElementById('in-blended-pct').addEventListener('input', () => { lastFreeInput = 'margin'; update(); });
        document.getElementById('m-cpc').addEventListener('change', update);
        ['m-plat', 'm-pgw', 'm-ship', 'm-aff-pct', 'm-aff-fix', 'm-dist', 'm-ads', 'm-kol'].forEach(id => { if($(id)) $(id).addEventListener('change', update); });

        ['rev', 'gp'].forEach(k => {
            const el = document.getElementById('in-' + k);
            el.addEventListener('input', function () {
                formatInputThousand(this);
            });
            el.addEventListener('change', function () { if (!LOCKS[k]) toggleLock(k); else update(); });
        });

        document.getElementById('sl-ret').addEventListener('input', function () { document.getElementById('in-ret').value = this.value; update(); });
        document.getElementById('in-ret').addEventListener('change', function () { document.getElementById('sl-ret').value = this.value; update(); });

        function initInputMasks() {
            ['in-price', 'in-cogs', 'in-traffic', 'in-rev', 'in-gp', 'm-cpc', 'm-ship', 'm-ads', 'in-fixed'].forEach(id => {
                const el = $(id);
                if (el) {
                    el.type = 'text';
                    formatInputThousand(el);
                }
            });
        }

        renderLockInterface();
        initInputMasks();
        applyBizPreset();
    </script>
