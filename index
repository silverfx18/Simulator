        // HELPER: Format input dengan pemisah ribuan (titik)
        function formatInputThousand(element) {
            let value = element.value.toString().replace(/\D/g, "");
            if (value === "") { element.value = ""; return; }
            element.value = parseInt(value, 10).toLocaleString('id-ID');
        }

        // HELPER: Mengambil angka murni dari string berformat titik
        function parseFormattedNum(id) {
            const val = document.getElementById(id).value.toString();
            return parseFloat(val.replace(/\./g, '')) || 0;
        }

        // HELPER: Sinkronisasi Traffic Input dan Slider secara dinamis agar tidak mentok
        function syncTrafficInputAndSlider(val) {
            const sl = document.getElementById('sl-traffic');
            const num = document.getElementById('in-traffic');
            const MAX_ALLOWED = 10000000; // Cap absolut 10 juta traffic
            const cleanVal = Math.max(10, Math.min(MAX_ALLOWED, Math.round(val)));
            if (cleanVal > +sl.max) {
                sl.max = Math.min(MAX_ALLOWED, Math.round(cleanVal * 1.2));
            }
            num.value = cleanVal.toLocaleString('id-ID');
            sl.value = cleanVal;
        }
        
        // HELPER: Logika distribusi beban pertumbuhan (Phased Growth: CR first -> Proportion)
        function calcBalancedDistribution(unitsNeeded, anchorT, anchorCr, biz, splitRatio) {
            const crNorm = biz.crNorm / 100;
            const crMax = biz.crMax / 100;
            const crMin = biz.crMin / 100;
            const targetQty = unitsNeeded;
            const currentQty = anchorT * anchorCr;

            let finalT, finalCr;

            if (targetQty > currentQty) {
                // Skenario Pertumbuhan
                // Phased Growth: Prioritas menaikkan CR dulu sampai ke angka Normal Industri sebelum naikkan Traffic
                const qtyAtNorm = anchorT * Math.max(anchorCr, crNorm);
                if (targetQty <= qtyAtNorm) {
                    // Tahap 1: Target bisa dicapai hanya dengan optimasi CR menuju norm industri (Traffic tetap)
                    finalT = anchorT;
                    finalCr = targetQty / anchorT;
                } else {
                    // Tahap 2: CR sudah di atas norm industri, sisanya bagi beban antara Traffic & CR sesuai slider
                    const extraGrowthNeeded = targetQty / qtyAtNorm;
                    finalT = anchorT * Math.pow(extraGrowthNeeded, splitRatio);
                    finalCr = Math.max(anchorCr, crNorm) * Math.pow(extraGrowthNeeded, 1 - splitRatio);
                }
            } else {
                // Skenario Penurunan: Gunakan distribusi power split standar
                const g = currentQty > 0 ? (targetQty / currentQty) : 1;
                finalT = anchorT * Math.pow(g, splitRatio);
                finalCr = anchorCr * Math.pow(g, 1 - splitRatio);
            }
            // Final Safety Clamping agar tetap dalam batas industri
            if (finalCr > crMax) { finalCr = crMax; finalT = targetQty / crMax; }
            else if (finalCr < crMin) { finalCr = crMin; finalT = targetQty / crMin; }
            return { traffic: finalT, cr: finalCr };
        }
        
        // ─── HELPER TERPUSAT: hitung unit contribution per penjualan ───────────
        function calcUnitContribution(price, cogs, cr, retention) {
            let vMktUnit = 0;
            if (mktTab === 'adv') {
                const plat = (parseFloat($('m-plat').value) || 0) / 100;
                const pgw = (parseFloat($('m-pgw').value) || 0) / 100;
                const affPct = (parseFloat($('m-aff-pct').value) || 0) / 100;
                
                // Persentase
                vMktUnit = (plat + pgw + affPct) * price;
                
                // Nominal Fix
                vMktUnit += parseFormattedNum('m-ship');
                vMktUnit += parseFormattedNum('m-aff-fix');
                vMktUnit += parseFormattedNum('m-dist');
            }
            
            let contrib = (price - cogs - vMktUnit) * (1 + retention);
            if (mktTab === 'simple') contrib -= (+document.getElementById('m-cpc').value || 0) / (cr > 0 ? cr : 0.01);
            return contrib;
        }

        // ─── HELPER: hitung unitsNeeded untuk target GP ──────────────────────
        function calcUnitsNeededForTarget(price, cogs, cr, retention, targetGP) {
            const contrib = calcUnitContribution(price, cogs, cr, retention);
            const adsPool = mktTab === 'adv' ? (parseFormattedNum('m-ads') + parseFormattedNum('m-kol')) : 0;
            
            // Proteksi: Jika kontribusi margin <= 0, target tidak mungkin dicapai dengan volume
            if (contrib <= 0) return 0;
            
            return (targetGP + adsPool) / (contrib / (1 + retention));
        }


        // MASTER DATABASE INDUSTRI & ELASTISITAS SEKTORAL
        const BIZ = {
            'ecomm-commodity': { label: 'E-commerce Commodity', effortT: 'Sedang', effortCR: 'Tinggi', crNorm: 1.2, crMin: 0.1, crMax: 10.0, splitDefault: 0.70, tDrop: 15, crDrop: 18 },
            'ecomm-niche': { label: 'E-commerce Niche', effortT: 'Tinggi', effortCR: 'Rendah', crNorm: 3.0, crMin: 0.5, crMax: 20.0, splitDefault: 0.30, tDrop: 5, crDrop: 8 },
            'ecomm-premium': { label: 'E-commerce Premium / Luxury', effortT: 'Tinggi', effortCR: 'Tinggi', crNorm: 1.8, crMin: 0.2, crMax: 15.0, splitDefault: 0.50, tDrop: 2, crDrop: 3 },
            'retail-commodity': { label: 'Retail Offline Mass Market', effortT: 'Tinggi', effortCR: 'Rendah', crNorm: 15.0, crMin: 2.0, crMax: 60.0, splitDefault: 0.30, tDrop: 8, crDrop: 12 },
            'retail-niche': { label: 'Retail Offline Niche/Spesialis', effortT: 'Sedang', effortCR: 'Rendah', crNorm: 20.0, crMin: 5.0, crMax: 70.0, splitDefault: 0.40, tDrop: 4, crDrop: 6 },
            'retail-premium': { label: 'Retail Offline Premium', effortT: 'Sedang', effortCR: 'Sedang', crNorm: 10.0, crMin: 1.0, crMax: 40.0, splitDefault: 0.50, tDrop: 2, crDrop: 3 },
            'service-relational': { label: 'Jasa Profesional Relasional', effortT: 'Sedang', effortCR: 'Tinggi', crNorm: 5.0, crMin: 1.0, crMax: 40.0, splitDefault: 0.70, tDrop: 4, crDrop: 5 }
        };
        
        // PERBAIKAN 1: Default Lock dibuka (false) di startup agar pipeline data berjalan mulus tanpa mengunci loop grafik
        const LOCKS = { price: false, cogs: false, traffic: false, cr: false, rev: false, gp: false };
        let lastFreeInput = 'traffic';
        let savedScenarios = [];
        let mktTab = 'simple';
        let reportFormat = 'txt';
        let sweetSpotChart = null;
        let internalMutex = false;
        let priceInputTimer = null;

        let dynamicBaselinePrice = 200000;
        let initialTrafficBeforeDrag = 50000;
        let initialCrBeforeDrag = 3.0;

        let isBaselineLocked = false;
        let storedBaselineData = { price: 200000, cogs: 100000, traffic: 50000, cr: 0.03, fixed: 30000000, retention: 0, tDrop: 0.05, crDrop: 0.08 };

        function lockInitialBaseline() {
            if (isBaselineLocked) {
                unlockInitialBaseline();
                return;
            }
            const currentInputs = getRawInputs();
            const mods = getElastModifiers();
            const cat = document.getElementById('biz-cat').value;
            const biz = BIZ[cat];

            storedBaselineData = {
                price: currentInputs.price,
                cogs: currentInputs.cogs,
                traffic: currentInputs.traffic,
                cr: currentInputs.cr,
                fixed: currentInputs.fixed,
                retention: currentInputs.retention,
                tDrop: mods.tDrop,
                crDrop: mods.crDrop
            };

            dynamicBaselinePrice = currentInputs.price;
            initialTrafficBeforeDrag = currentInputs.traffic;
            initialCrBeforeDrag = currentInputs.cr * 100;

            isBaselineLocked = true;

            // Otomatis izinkan HPP > AOV saat baseline dikunci
            currentCapMode = 'allow';
            const capBtn = document.getElementById('btn-cap-toggle');
            if (capBtn) capBtn.classList.add('active');

            const slPrice = document.getElementById('sl-price');
            const slCogs = document.getElementById('sl-cogs');

            // Sinkronkan skala slider AOV dan HPP berdasarkan nilai tertinggi agar posisi visual sebanding
            const baseVal = Math.max(currentInputs.price, currentInputs.cogs);
            const maxVal = Math.round(baseVal * 5);
            const stepVal = baseVal < 50000 ? 500 : 1000;

            [slPrice, slCogs].forEach(s => {
                s.min = 0;
                s.max = maxVal;
                s.step = stepVal;
            });

            const slTraffic = document.getElementById('sl-traffic');
            slTraffic.min = Math.max(10, Math.round(currentInputs.traffic * 0.1));
            slTraffic.max = Math.max(500000, Math.round(currentInputs.traffic * 10));
            
            const btn = document.getElementById('btn-lock-baseline');
            btn.innerHTML = `<i data-lucide="target" style="width:14px; height:14px;"></i> Lepas Baseline`;
            btn.style.background = `var(--color-warning)`;
            btn.style.color = `#856404`;
            lucide.createIcons();
            
            document.getElementById('btn-restore-baseline').style.display = 'inline-flex';
            
            update();
        }

        function unlockInitialBaseline() {
            isBaselineLocked = false;

            // Kembalikan ke mode strict saat baseline dilepas
            currentCapMode = 'strict';
            const capBtn = document.getElementById('btn-cap-toggle');
            if (capBtn) capBtn.classList.remove('active');

            const slPrice = document.getElementById('sl-price');
            const slCogs = document.getElementById('sl-cogs');
            [slPrice, slCogs].forEach(s => {
                s.min = 0;
                s.max = 2000000;
                s.step = 1000;
            });

            const slTraffic = document.getElementById('sl-traffic');
            slTraffic.min = 100;
            slTraffic.max = 500000;
            
            const btn = document.getElementById('btn-lock-baseline');
            btn.innerHTML = `<i data-lucide="target" style="width:14px; height:14px;"></i> Kunci Baseline`;
            btn.style.background = ``;
            btn.style.color = ``;
            lucide.createIcons();
            
            document.getElementById('btn-restore-baseline').style.display = 'none';
            
            update();
        }

        function restoreToBaseline() {
            if (!isBaselineLocked) return;

            // Kembalikan nilai input dari data baseline yang tersimpan
            document.getElementById('in-price').value = storedBaselineData.price;
            document.getElementById('in-cogs').value = storedBaselineData.cogs;
            document.getElementById('in-traffic').value = storedBaselineData.traffic;
            document.getElementById('in-cr').value = (storedBaselineData.cr * 100).toFixed(1);
            document.getElementById('in-fixed').value = storedBaselineData.fixed;
            document.getElementById('in-ret').value = (storedBaselineData.retention * 100);

            // Sinkronisasi slider
            document.getElementById('sl-price').value = storedBaselineData.price;
            document.getElementById('sl-cogs').value = storedBaselineData.cogs;
            document.getElementById('sl-traffic').value = Math.min(500000, storedBaselineData.traffic);
            document.getElementById('sl-cr').value = (storedBaselineData.cr * 100);
            document.getElementById('sl-ret').value = (storedBaselineData.retention * 100);

            // Format ulang ribuan agar visual tetap rapi
            ['in-price', 'in-cogs', 'in-traffic', 'in-fixed'].forEach(id => {
                formatInputThousand(document.getElementById(id));
            });

            // Reset benchmark internal agar kalkulasi elastisitas tidak melompat
            resetBaselineBenchmarks();
            
            // Jalankan update UI menyeluruh
            update();
        }

        function applyParetoAdjustment() {
            const gpValue = parseFormattedNum('in-gp');
            if (!LOCKS.gp || gpValue <= 0) return;

            let { price, cogs, traffic, cr, retention } = getRawInputs();
            const biz = BIZ[document.getElementById('biz-cat').value];

            const unitsNeeded = calcUnitsNeededForTarget(price, cogs, cr, retention, gpValue);
            let split = (+document.getElementById('sl-weight-split').value || (biz.splitDefault * 100)) / 100;
            let dist = calcBalancedDistribution(unitsNeeded, traffic, cr, biz, split);

            syncTrafficInputAndSlider(dist.traffic);
            document.getElementById('in-cr').value = +(dist.cr * 100).toFixed(2);
            document.getElementById('sl-cr').value = Math.min(biz.crMax, dist.cr * 100);

            LOCKS.traffic = false; LOCKS.cr = false; lastFreeInput = 'traffic';
            renderLockInterface();
        }

        function renderVisualShadowIndicators(current) {
            if (!isBaselineLocked) {
                document.getElementById('sh-price').textContent = "";
                document.getElementById('sh-cogs').textContent = "";
                document.getElementById('sh-traffic').textContent = "";
                document.getElementById('sh-cr').textContent = "";
                return;
            }

            const dPrice = ((current.price - storedBaselineData.price) / storedBaselineData.price * 100);
            const dCogs = ((current.cogs - storedBaselineData.cogs) / storedBaselineData.cogs * 100);
            const dTraffic = ((current.traffic - storedBaselineData.traffic) / storedBaselineData.traffic * 100);
            const dCr = (((current.cr * 100) - (storedBaselineData.cr * 100)) / (storedBaselineData.cr * 100) * 100);

            document.getElementById('sh-price').innerHTML = `Awal: ${fmt(storedBaselineData.price)} (${dPrice >= 0 ? '+' : ''}${dPrice.toFixed(0)}%)`;
            document.getElementById('sh-cogs').innerHTML = `Awal: ${fmt(storedBaselineData.cogs)} (${dCogs >= 0 ? '+' : ''}${dCogs.toFixed(0)}%)`;
            document.getElementById('sh-traffic').innerHTML = `Awal: ${fmtN(storedBaselineData.traffic)} (${dTraffic >= 0 ? '+' : ''}${dTraffic.toFixed(0)}%)`;
            document.getElementById('sh-cr').innerHTML = `Awal: ${(storedBaselineData.cr * 100).toFixed(1)}% (${dCr >= 0 ? '+' : ''}${dCr.toFixed(0)}%)`;
        }

        function applyBizPreset() {
            const cat = document.getElementById('biz-cat').value;
            const biz = BIZ[cat];
            const isCustomActive = document.getElementById('chk-custom-elast').checked;

            const slCr = document.getElementById('sl-cr');
