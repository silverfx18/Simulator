                errorBox.innerHTML = `<i data-lucide="alert-octagon" style="width:14px; height:14px; display:inline-block; vertical-align:middle;"></i> <strong>${cogs > price ? 'MARGIN NEGATIF (LOSS):' : 'BREAK EVEN POINT:'}</strong> HPP unit (${fmt(cogs)}) ${cogs > price ? 'melebihi' : 'menyamai'} Harga Jual (${fmt(price)}). Simulasi tetap menghitung proyeksi kerugian.`;
