    <script>
        const fmt = n => 'Rp ' + Math.round(n).toLocaleString('id-ID');
        const fmtN = n => Math.round(n).toLocaleString('id-ID');
        const fmtP = n => n.toFixed(2) + '%';
        const $ = id => document.getElementById(id);
        
        // Initialize Lucide Icons
        lucide.createIcons();

        // Logika Mutually Exclusive untuk Komisi
        let ownerReportFormat = 'txt';
        function lockAff(type) {
            if(type === 'pct') {
                if(parseFloat($('m-aff-pct').value) > 0) {
